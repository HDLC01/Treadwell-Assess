# ─── Treadwell Assess — backend config ───────────────────────────────────────
# Copy to `.env`. Everything has a dev-safe default; the app starts without this file.

ENVIRONMENT=development            # development | production

# Postgres (compose service `db`; local dev publishes 127.0.0.1:5434)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434
POSTGRES_DB=assess
POSTGRES_USER=assess
POSTGRES_PASSWORD=assess-dev-password

# Seed a demo job + assessment link (token `demo`) on startup — development only.
DEV_BOOTSTRAP=true

# Scoring: raw factor score -> sigma scale divisor (calibratable from real data later).
SCORE_SCALE=2.5

# CORS (the Next.js dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Employer auth (Supabase Google sign-in) — AUTH ONLY ─────────────────────
# Reuses the shared Treadwell cloud Supabase project. Leave UNSET to run the
# employer side OPEN in local dev (the candidate /assess flow is always open).
# The anon key is publishable (safe in the browser); the JWT secret stays server-side.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
AUTH_ALLOWED_DOMAIN=wetreadwell.com
